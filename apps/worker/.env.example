# Vite build-time client env (apps/worker/index.html → src/client/main.ts)
#
# これらは vite build 時に bundle に焼き込まれます。
# `apps/worker/.env` (gitignore 済み) にコピーして実値を入れてください。
# CI では GitHub Secrets から渡してください。
#
# 不足時: scripts/preflight.mjs の liff-bundle チェックが CRITICAL を出します
# (本番事故 2026-04-28 「読み込み中...」固着の再発防止)。

# 必須: LIFF アプリの ID (LINE Developers > LINE Login channel > LIFF タブで取得)
# 形式: 10 桁数字 + ハイフン + 8 文字英数字
VITE_LIFF_ID=2009XXXXXXX-XXXXXXXX

# 任意: LINE 公式アカウントの Bot Basic ID (友だち追加 URL に使う)
# 形式: @xxxx (LINE Official Account Manager > 設定 > 基本情報)
VITE_BOT_BASIC_ID=
