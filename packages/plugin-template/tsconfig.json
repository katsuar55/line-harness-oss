{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    // mcp-server/ は Node.js で動くため node 型を含む。worker 部分 (src/) は @cloudflare/workers-types で賄う。
    "types": ["@cloudflare/workers-types", "node"]
  },
  "include": ["src/**/*.ts", "mcp-server/**/*.ts"]
}
